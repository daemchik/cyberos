# MySQL (same variables as before under Node)
DB_HOST=127.0.0.1
DB_PORT=3306
# Имя базы — как в `USE ...` в начале backend/schema.sql
DB_NAME=cyberos
DB_USER=root
DB_PASSWORD=

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend dev server (Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT (опционально; иначе используется DJANGO_SECRET_KEY)
JWT_SIGNING_KEY=

# Агент на ПК: тот же секрет в заголовке X-Agent-Token
AGENT_SHARED_SECRET=dev-agent-secret
